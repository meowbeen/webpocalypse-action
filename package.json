{
  "name": "webpocalypse-action",
  "version": "1.0.0",
  "description": "GitHub Action to automatically optimize images using the webpocalypse CLI",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:clean": "rimraf dist && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@vercel/ncc": "^0.38.2",
    "rimraf": "^5.0.9",
    "typescript": "^5.4.5"
  }
}
